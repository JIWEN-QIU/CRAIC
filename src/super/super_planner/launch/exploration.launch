<launch>
    <arg name="odom_topic" default="/odin1/odometry_highfreq"/>
    <arg name="cloud_topic" default="/odin1/cloud_slam"/>
    <!-- Preview-only fixed odom-z override, disabled for real flight.
    <arg name="preview_fixed_odom_z" default="false"/>
    <arg name="preview_odom_topic" default="/super_preview/odom"/>
    <arg name="preview_odom_z" default="0.3"/>
    -->
    <!-- > -5 fixes click goal height; <= -5 uses the current odom z. -->
    <arg name="click_height" default="1.6"/>

    <node pkg="super_planner" name="fsm_node" type="fsm_node" output="screen">
    <rosparam command="load" file="$(find super_planner)/config/exp_advanced_params.yaml"></rosparam>
    <rosparam command="load" file="$(find super_planner)/config/exp.yaml"></rosparam>
    <param name="rog_map/ros_callback/odom_topic" value="$(arg odom_topic)"/>
    <param name="rog_map/ros_callback/cloud_topic" value="$(arg cloud_topic)"/>
    <!-- Preview-only fixed odom-z override, disabled for real flight.
    <param name="rog_map/ros_callback/override_odom_z_enabled" value="$(arg preview_fixed_odom_z)"/>
    <param name="rog_map/ros_callback/override_odom_z" value="$(arg preview_odom_z)"/>
    -->
    <param name="fsm/click_height" value="$(arg click_height)"/>
    </node>
</launch>
