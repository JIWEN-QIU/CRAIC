    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /PointCloud21/Autocompute Value Bounds1
        - /PointCloud22/Autocompute Value Bounds1
      Splitter Ratio: 0.4701670706272125
